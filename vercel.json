{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "true",
  "buildCommand": "true",
  "outputDirectory": ".",
  "headers": [
    {
      "source": "/(.*)\\.json",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=300, s-maxage=300, stale-while-revalidate=86400"
        }
      ]
    },
    {
      "source": "/(.*)\\.(html|css|js|svg)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, s-maxage=3600"
        }
      ]
    }
  ]
}
